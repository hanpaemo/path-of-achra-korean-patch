[sub_resource type="GDScript" id=8]
script/source = "extends Node2D


var rng = RandomNumberGenerator.new()
var rects = []
var rects_faded = []

func _ready():
	rng.randomize()
	var size = 65
	for x in 20:
		for y in 10:
			var rect = ColorRect.new()
			rect.mouse_filter = Control.MOUSE_FILTER_IGNORE
			add_child(rect)
			rect.color = Color(0,0,0,1)
			rect.rect_size.x = size
			rect.rect_size.y = size
			rect.rect_position.x = x*size
			rect.rect_position.y = y*size
			rects.append(rect)

func _process(_delta):
	for n in 3:
		if rects_faded.size()>0:
			var r = rng.randi_range(0,rects_faded.size()-1)
			var rect = rects_faded[r]
			rects_faded.erase(rect)
			rect.queue_free()

	for n in 6:
		if rects.size()>0:
			var r = rng.randi_range(0,rects.size()-1)
			var rect = rects[r]
			rects.erase(rect)
			rects_faded.append(rect)
			rect.color = Color(0,0,0,.7)

		else:
			if rects_faded.size()<=0:
				queue_free()
"

